---
import Layout from '../layouts/Layout.astro';
import PillArrowBtn from '@aksell/ui/pillarrowbtn';
---

<Layout title="{{project-name}}">
  <main class="container">
    <h1>{{project-name}}</h1>

    <section>
      <h2>Buttons</h2>
      <div class="btn-row">
        <button class="btn btn--primary">Primary</button>
        <button class="btn btn--secondary">Secondary</button>
        <button class="btn btn--accent">Accent</button>
        <button class="btn btn--dark">Dark</button>
        <button class="btn btn--light">Light</button>
        <button class="btn btn--contrast">Contrast</button>
      </div>
      <div class="btn-row">
        <button class="btn btn--danger">Danger</button>
        <button class="btn btn--success">Success</button>
        <button class="btn btn--warning">Warning</button>
      </div>
      <div class="btn-row">
        <button class="btn btn--primary btn--outline">Outline</button>
        <button class="btn btn--primary btn--sm">Small</button>
        <button class="btn btn--ghost">Ghost</button>
      </div>
    </section>

    <section>
      <h2>Toast</h2>
      <div class="btn-row">
        <button class="btn btn--success" data-toast="success" data-toast-msg="Saved successfully">Toast success</button>
        <button class="btn btn--danger" data-toast="error" data-toast-msg="Something went wrong">Toast error</button>
        <button class="btn btn--primary" data-toast="info" data-toast-msg="Here's some info">Toast info</button>
        <button class="btn btn--warning" data-toast="warning" data-toast-msg="Watch out">Toast warning</button>
      </div>
    </section>

    <section>
      <h2>Typography</h2>
      <p>The quick brown fox <strong>jumps</strong> over the <em>lazy</em> dog. <a href="#">A link</a>.</p>
      <h3>Heading 3</h3>
      <h4>Heading 4</h4>
    </section>

    <section>
      <h2>Form elements</h2>
      <form onsubmit="event.preventDefault()">
        <label for="text">Text</label>
        <input type="text" id="text" name="text" placeholder="Text" />

        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="Email" autocomplete="email" />

        <label for="select">Select</label>
        <select id="select" name="select">
          <option value="" selected>Select…</option>
          <option>Option 1</option>
          <option>Option 2</option>
        </select>

        <fieldset>
          <legend><strong>Checkboxes</strong></legend>
          <label for="checkbox-1">
            <input type="checkbox" id="checkbox-1" name="checkbox-1" checked />
            Option A
          </label>
          <label for="checkbox-2">
            <input type="checkbox" id="checkbox-2" name="checkbox-2" />
            Option B
          </label>
        </fieldset>

        <button type="submit" class="btn btn--primary">Submit</button>
      </form>
    </section>

    <section>
      <h2>Pill Arrow</h2>
      <PillArrowBtn href="/" title="Go home" target="_self" variant="primary" />
      <PillArrowBtn href="/" title="Dark variant" target="_self" variant="dark" />
      <PillArrowBtn href="/" title="Dark accent" target="_self" variant="darkaccent" />
      <PillArrowBtn title="Button (no href)" variant="primary" />
    </section>
  </main>
</Layout>

<script>
  import { showToast } from '@aksell/ui/toast';

  document.querySelectorAll<HTMLButtonElement>('[data-toast]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const variant = btn.dataset.toast as 'success' | 'error' | 'info' | 'warning';
      const message = btn.dataset.toastMsg ?? 'Toast';
      showToast(message, { variant });
    });
  });
</script>

<style>
  .container {
    max-width: 1500px;
    width: calc(100% - 3rem);
    margin: auto;
    padding-block: 2rem;
  }

  section {
    margin-block: 2rem;
  }

  h2 {
    margin-bottom: 1rem;
  }

  .btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
</style>
